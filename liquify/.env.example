# Liquify — Environment Variables
# Copy to .env and fill in

# Prediction market API key (get from your profile => Edit => API key)
MANIFOLD_API_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Username of the account that owns the API key
MANIFOLD_USERNAME=YourUsername

# Backend URL (optional — defaults to prod)
# Prod: https://api.oracle.markets/v0
# Dev:  https://api.dev.oracle.markets/v0
# ORACLE_API_URL=https://api.dev.oracle.markets/v0
