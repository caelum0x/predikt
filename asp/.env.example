# Server key for OpenRouter chat completions. Required.
OPENROUTER_API_KEY=

# Model to use. Defaults to a free-tier model when unset.
AI_MODEL=meta-llama/llama-3.1-8b-instruct:free

# Optional OpenRouter attribution headers (no secrets).
OPENROUTER_SITE_URL=
OPENROUTER_SITE_NAME=Predikt Oracle

# HTTP port. Defaults to 8787.
PORT=8787
