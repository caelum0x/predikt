# relay-tg — Environment Variables
# Copy to .env and fill in. Do NOT commit .env.

# Telegram Bot API token from @BotFather (https://t.me/BotFather)
BOT_TOKEN=123456789:AA-your-telegram-bot-token

# Base URL of the Predikt/oracle backend. Optional — defaults to prod.
#   Prod: https://api.oracle.markets/v0   Dev: https://api.dev.oracle.markets/v0
ORACLE_API_URL=https://api.oracle.markets/v0

# Optional fallback API key for unauthenticated market reads.
# Per-user keys registered via /register are stored separately in keys.json.
# ORACLE_API_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# REQUIRED: secret used to encrypt users' trading API keys at rest.
# keys.json stores each per-user key encrypted with AES-256-GCM, using a key
# derived (scrypt) from this secret. Use a long, random value and keep it out of
# version control. If it is unset the bot warns loudly and cannot encrypt/decrypt
# keys. Changing it makes any previously stored keys undecryptable (users must
# /register again). Generate one with:  openssl rand -base64 48
KEY_ENCRYPTION_SECRET=replace-with-a-long-random-secret

# SECURITY: keys.json holds users' trading API keys ENCRYPTED at rest (AES-256-GCM).
# It is still git-ignored — never commit it — and the bot's directory should not be
# world-readable (chmod 700 the dir / chmod 600 keys.json).
