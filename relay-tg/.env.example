# relay-tg — Environment Variables
# Copy to .env and fill in. Do NOT commit .env.

# Telegram Bot API token from @BotFather (https://t.me/BotFather)
BOT_TOKEN=123456789:AA-your-telegram-bot-token

# Base URL of the Predikt/oracle backend. Optional — defaults to prod.
#   Prod: https://api.oracle.markets/v0   Dev: https://api.dev.oracle.markets/v0
ORACLE_API_URL=https://api.oracle.markets/v0

# Optional fallback API key for unauthenticated market reads.
# Per-user keys registered via /register are stored separately in keys.json.
# ORACLE_API_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# SECURITY: keys.json holds users' trading API keys in PLAINTEXT.
# It is git-ignored — never commit it — and the bot's directory must not be
# world-readable (chmod 700 the dir / chmod 600 keys.json).
